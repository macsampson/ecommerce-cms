# Database Configuration
# If you deployed via the "Deploy to Vercel" button, the bundled Neon Postgres
# integration already provisioned DATABASE_URL and DATABASE_URL_UNPOOLED for
# you — you don't need to set DIRECT_URL yourself, `npm run deploy` falls back
# to DATABASE_URL_UNPOOLED automatically. For local dev or Supabase, set both:
DATABASE_URL="postgresql://postgres:password@localhost:54322/postgres?schema=public"
DIRECT_URL="postgresql://postgres:password@localhost:54322/postgres?schema=public"

# Admin Authentication
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="" # Generate with: node scripts/generate-password-hash.js
SESSION_SECRET="" # Generate 32+ character secret key

# Local dev only — skips the login gate so the dashboard is reachable without
# the admin password. Leave unset (or "false") everywhere else: auth is
# enforced by default, and this must be deliberately opted into, never implied
# by environment. Never set this on a real deployment.
DISABLE_AUTH_FOR_LOCAL_DEV="true"

# Stripe Payments
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Image Storage (Cloudinary)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# API Configuration
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Optional: Shipping APIs — these can also be set per-store from the
# Shipping settings page in the dashboard, which takes precedence over these.
SHIPPO_API_KEY=""
CHITCHATS_API_KEY=""
CHITCHATS_API_URL=""
CHITCHATS_CLIENT_ID=""

# Optional: Exchange Rate API
EXCHANGE_RATE_API_KEY=""

# Optional: set to "true" to run this deployment as a public, read-only demo —
# blocks all write requests to the admin API regardless of who's logged in.
# See lib/demo-mode.ts. Seed sample data first with `npm run seed-demo`.
DEMO_MODE="false"
# Must be set to the same value as DEMO_MODE, in addition to it. Image uploads go
# straight from the browser to Cloudinary and never hit our API, so the write-block
# above can't see them — this separate NEXT_PUBLIC_ var lets the (client-side) upload
# widget know to disable itself too.
NEXT_PUBLIC_DEMO_MODE="false"