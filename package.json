{
  "name": "stockroom",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "dev": "supabase start && next dev --port 3000",
    "dev:docker": "docker compose up -d && npx prisma migrate deploy && next dev --port 3000",
    "dev:fullstack": "concurrently --kill-others --success first \"supabase start && next dev --port 3000\" \"wait-on http://localhost:3000/sign-in && bun run cron\" \"wait-on http://localhost:3000/sign-in && stripe.exe listen --forward-to localhost:3000/api/webhook\" \"cd ../frontend && bun run dev\"",
    "cron": "node cron.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "deploy": "DIRECT_URL=\"${DIRECT_URL:-$DATABASE_URL_UNPOOLED}\" prisma migrate deploy",
    "migrate:rollback": "prisma migrate resolve --rolled-back",
    "seed-dev": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-dev.ts",
    "seed-demo": "npx ts-node --compiler-options '{\"module\":\"CommonJS\"}' prisma/seed-demo.ts"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed-dev.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.2",
    "@prisma/client": "^5.14.0",
    "@radix-ui/react-checkbox": "^1.3.8",
    "@radix-ui/react-dialog": "^1.1.20",
    "@radix-ui/react-dropdown-menu": "^2.1.21",
    "@radix-ui/react-label": "^2.1.12",
    "@radix-ui/react-popover": "^1.1.20",
    "@radix-ui/react-select": "^2.3.4",
    "@radix-ui/react-separator": "^1.1.12",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.5",
    "@tanstack/react-table": "^8.10.7",
    "@vercel/analytics": "^2.0.1",
    "axios": "^1.18.1",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^0.2.0",
    "date-fns": "^2.30.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.286.0",
    "next": "^16.2.10",
    "next-cloudinary": "^6.5.2",
    "next-themes": "^0.2.1",
    "node-cron": "^4.6.0",
    "pino": "^10.3.1",
    "react": "^18",
    "react-day-picker": "^9.9.0",
    "react-dom": "^18",
    "react-hook-form": "^7.47.0",
    "react-hot-toast": "^2.6.0",
    "react-spinners": "^0.13.8",
    "recharts": "^2.15.4",
    "shippo": "^1.7.1",
    "stripe": "^14.1.0",
    "tailwind-merge": "^1.14.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^14.0.1",
    "zod": "^3.25.76",
    "zustand": "^4.4.3"
  },
  "overrides": {
    "sharp": "^0.35.3",
    "@istanbuljs/load-nyc-config": {
      "js-yaml": "^3.15.0"
    },
    "brace-expansion": "^2.1.2"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/shippo": "^1.7.5",
    "autoprefixer": "^10",
    "concurrently": "^8.2.2",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "jest": "^29.7.0",
    "jest-mock-extended": "^3.0.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8",
    "prisma": "^5.14.0",
    "tailwindcss": "^3",
    "ts-jest": "^29.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wait-on": "^7.2.0"
  },
  "allowScripts": {
    "prisma": true,
    "@prisma/client": true,
    "@prisma/engines": true
  }
}
